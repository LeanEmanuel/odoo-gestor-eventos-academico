<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Vista de lista -->
    <record id="view_tag_list" model="ir.ui.view">
        <field name="name">gestor.tag.list</field>
        <field name="model">gestor.tag</field>
        <field name="arch" type="xml">
            <list string="Etiquetas">
                <field name="name"/>
                <field name="color"/>
            </list>
        </field>
    </record>

    <!-- Vista de formulario -->
    <record id="view_tag_form" model="ir.ui.view">
        <field name="name">gestor.tag.form</field>
        <field name="model">gestor.tag</field>
        <field name="arch" type="xml">
            <form string="Etiqueta">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción para mostrar las vistas -->
    <record id="action_tag_list" model="ir.actions.act_window">
        <field name="name">Etiquetas</field>
        <field name="res_model">gestor.tag</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>