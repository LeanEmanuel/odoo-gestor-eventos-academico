<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Lista -->
    <record id="view_expense_list" model="ir.ui.view">
        <field name="name">gestor.expense.list</field>
        <field name="model">gestor.expense</field>
        <field name="arch" type="xml">
            <list string="Expenses">
                <field name="concept"/>
                <field name="amount"/>
                <field name="payment_status"/>
                <field name="payment_date"/>
                <field name="event_id"/>
                <field name="notes"/>
            </list>
        </field>
    </record>

    <!-- Formulario -->
    <record id="view_expense_form" model="ir.ui.view">
        <field name="name">gestor.expense.form</field>
        <field name="model">gestor.expense</field>
        <field name="arch" type="xml">
            <form string="Expense">
                <sheet>
                    <group>
                        <field name="concept"/>
                        <field name="amount"/>
                        <field name="date"/>
                        <field name="payment_status"/>
                        <field name="payment_date"/>
                        <field name="event_id"/>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción para mostrar vista -->
    <record id="action_expense_list" model="ir.actions.act_window">
        <field name="name">Gastos</field>
        <field name="res_model">gestor.expense</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
