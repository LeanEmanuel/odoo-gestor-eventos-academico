<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ticket_list" model="ir.ui.view">
        <field name="name">event.ticket.list</field>
        <field name="model">event.ticket</field>
        <field name="arch" type="xml">
            <list string="Tickets">
                <field name="ticket_type"/>
                <field name="price"/>
                <field name="status"/>
                <field name="event_id"/>
            </list>
        </field>
    </record>

    <record id="view_ticket_form" model="ir.ui.view">
        <field name="name">event.ticket.form</field>
        <field name="model">event.ticket</field>
        <field name="arch" type="xml">
            <form string="Ticket">
                <sheet>
                    <group>
                        <field name="ticket_type"/>
                        <field name="price"/>
                        <field name="status"/>
                        <field name="event_id"/>
                        <field name="qr_code"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
