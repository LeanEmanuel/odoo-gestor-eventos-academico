<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Menú principal -->
    <menuitem id="menu_gestor_eventos_root" name="Gestión de Eventos" sequence="10"/>

    <!-- Submenú para acceder a eventos -->
    <menuitem id="menu_eventos" name="Eventos" parent="menu_gestor_eventos_root"/>

    <!-- Acción de apertura de la vista list+form del modelo event.event -->
    <record id="action_event_event" model="ir.actions.act_window">
        <field name="name">Eventos</field>
        <field name="res_model">event.event</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Haz clic en crear para agregar un nuevo evento.
            </p>
        </field>
    </record>

    <!-- Menú final que lanza la acción -->
    <menuitem id="menu_eventos_action"
              name="Ver eventos"
              parent="menu_eventos"
              action="action_event_event"/>
</odoo>