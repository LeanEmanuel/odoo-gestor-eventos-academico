<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <!-- Vista de lista -->
    <record id="view_income_list" model="ir.ui.view">
        <field name="name">gestor.income.list</field>
        <field name="model">gestor.income</field>
        <field name="arch" type="xml">
            <list string="Ingresos">
                <field name="concept"/>
                <field name="amount"/>
                <field name="payment_status"/>
                <field name="payment_date"/>
                <field name="event_id"/>
                <field name="ticket_id"/>
            </list>
        </field>
    </record>

    <!-- Vista de formulario -->
    <record id="view_income_form" model="ir.ui.view">
        <field name="name">gestor.income.form</field>
        <field name="model">gestor.income</field>
        <field name="arch" type="xml">
            <form string="Ingreso">
                <sheet>
                    <group>
                        <field name="concept"/>
                        <field name="amount"/>
                        <field name="payment_status"/>
                        <field name="payment_date"/>
                    </group>
                    <group string="Relaciones">
                        <field name="event_id"/>
                        <field name="ticket_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción para mostrar vista -->
    <record id="action_income_list" model="ir.actions.act_window">
        <field name="name">Ingresos</field>
        <field name="res_model">gestor.income</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>